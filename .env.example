# Apple MapKit JS credentials
# Generate a MapKit JS key at https://developer.apple.com/account/resources/authkeys/list
# and fill in the values below. All three are required for the map to render.

# Your 10-character Apple Developer Team ID (top-right of the developer portal)
MAPKIT_TEAM_ID=

# The 10-character Key ID of the MapKit JS key you generated
MAPKIT_KEY_ID=

# MAPKIT_PRIVATE_KEY: contents of the downloaded .p8 file, including the
# BEGIN/END lines.
#
# Required format (both local .env and production): a DOUBLE-QUOTED string
# with every real newline replaced by the literal two-character escape "\n".
# This escaping is required for local .env parsing — an unquoted multi-line
# value will break dotenv. Example:
#
#   MAPKIT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGTAgEA...\n-----END PRIVATE KEY-----\n"
#
# When deploying to platforms like Vercel, paste the same escaped-\n string
# into the environment variable UI — preserve the \n sequences, don't expand
# them. The route handler at app/api/mapkit-token/route.ts rehydrates them at
# runtime with .replace(/\\n/g, "\n") before signing.
MAPKIT_PRIVATE_KEY=
